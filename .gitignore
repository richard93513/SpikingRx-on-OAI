# =========================
# Python Virtual Env
# =========================
.venv/
venv/
env/

# =========================
# Ignore bundle content but KEEP folder structure
# =========================
spx_records/snapshots_snr/bundle_noise_power_*/*

# keep empty placeholder
!spx_records/snapshots_snr/bundle_noise_power_*/.keep

# =========================
# Ignore large dataset JSON (move to Drive)
# =========================
spx_records/snapshots_snr/*batch_summary*.json
spx_records/snapshots_snr/oai_decode_detail.json

# =========================
# Keep plots / summaries
# =========================
!spx_records/snapshots_snr/*.png
!spx_records/snapshots_snr/*.csv
!spx_records/snapshots_snr/llr_*/
!spx_records/snapshots_snr/*metrics*/
!spx_records/snapshots_snr/*scatter*/
!spx_records/snapshots_snr/*hist*/

# =========================
# Python Cache
# =========================
__pycache__/
*.pyc
*.pyo

# =========================
# Jupyter
# =========================
.ipynb_checkpoints/

# =========================
# Logs / temp
# =========================
*.log
*.tmp

# =========================
# IDE
# =========================
.vscode/
.idea/

# =========================
# Models / binaries
# =========================
*.pth
*.pt
*.npy
*.bin

# =========================
# Docs (keep)
# =========================
!docs/
!docs/**
